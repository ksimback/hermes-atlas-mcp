  "license": "MIT",
  "homepage": "https://hermesatlas.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksimback/hermes-atlas-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ksimback/hermes-atlas-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
